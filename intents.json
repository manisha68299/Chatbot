{
  "intents": [
    {
      "tag": "greeting",
      "patterns": [
        "Hi", "Hello", "Hey", "Good morning", "Good evening",
        "Hi there", "Hello there", "Hey bot", "What's up", "Yo"
      ],
      "responses": [
        "Hello!", "Hi there!", "Hey! How can I help you today?"
      ]
    },
    {
      "tag": "goodbye",
      "patterns": [
        "Bye", "See you later", "Goodbye", "Take care",
        "Catch you later", "See ya", "Talk to you soon"
      ],
      "responses": [
        "Goodbye!", "See you soon!", "Take care and have a nice day!"
      ]
    },
    {
      "tag": "thanks",
      "patterns": [
        "Thanks", "Thank you", "Much appreciated", "Thanks a lot",
        "Thx", "Cheers", "Many thanks"
      ],
      "responses": [
        "You're welcome!", "Glad I could help!", "Anytime!"
      ]
    },
    {
      "tag": "name",
      "patterns": [
        "What is your name?", "Who are you?", "Tell me your name",
        "Introduce yourself", "What should I call you?"
      ],
      "responses": [
        "I’m your friendly chatbot!", "You can call me ChatBot 🤖"
      ]
    },
    {
      "tag": "mood",
      "patterns": [
        "How are you?", "How are you doing?", "Are you okay?",
        "How’s it going?", "What's up with you?"
      ],
      "responses": [
        "I’m just a bot, but I’m feeling great! 😊",
        "Doing well, thanks for asking!"
      ]
    },
    {
      "tag": "weather",
      "patterns": [
        "What’s the weather like?", "Tell me today’s weather", "Is it raining?",
        "How’s the weather?", "Weather update please"
      ],
      "responses": [
        "I can’t check the weather right now, but I recommend looking outside ☀️🌧️"
      ]
    },
    {
      "tag": "time",
      "patterns": [
        "What time is it?", "Tell me the time", "Current time?",
        "Do you know the time?", "Can you tell me the time?"
      ],
      "responses": [
        "I don’t have a watch, but your system clock does 🕒"
      ]
    },
    {
      "tag": "noanswer",
      "patterns": [],
      "responses": [
        "Sorry, I didn’t understand that. Can you rephrase?",
        "I’m not sure what you mean 🤔",
        "Could you ask that in another way?"
      ]
    }
  ]
